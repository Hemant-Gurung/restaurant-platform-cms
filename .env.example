# Database — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/restaurant

# SSL certificate validation (production only).
# Set to "false" ONLY if your DB provider uses a self-signed cert (e.g. some Supabase poolers).
# Default is "true" (validate certificates).
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Payload CMS secret (used to sign cookies/tokens — change in production!)
PAYLOAD_SECRET=your-long-random-secret-here

# Where the CMS runs (used for CORS and Payload server URL)
NEXT_PUBLIC_SERVER_URL=http://localhost:3002

# Comma-separated list of production frontend origins allowed by CORS
# e.g. ALLOWED_ORIGINS=https://myrestaurant.com,https://verdekitchen.com
ALLOWED_ORIGINS=

# Email sending via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# Vercel Blob storage for uploaded media (https://vercel.com/docs/storage/vercel-blob)
# Create a store in your Vercel project → Storage tab, then paste the token here.
# When set, all media uploads go to Blob instead of /public/media — required for
# persistent uploads on Vercel (the local filesystem is ephemeral).
# Leave empty in local development to use the local /public/media folder instead.
BLOB_READ_WRITE_TOKEN=

# DeepL — used for auto-translating SiteContent fields (tagline, description)
# Free tier: 500,000 chars/month — sign up at https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Stripe — per-restaurant keys are stored in the Restaurants collection in the CMS admin.
# Each restaurant's stripeSecretKey and stripeWebhookSecret is set by a super-admin.
# Webhook URL to register in each restaurant's Stripe dashboard:
#   https://<your-cms-domain>/api/webhooks/stripe/<restaurant-slug>
# Optional: payment currency, defaults to "gbp"
STRIPE_CURRENCY=gbp
